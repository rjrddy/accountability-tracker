generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  uid           String    @id
  email         String?
  displayName   String?
  photoURL      String?
  username      String?
  usernameLower String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  goals         Goal[]
  dayNotes      DayNote[]
  goalSeries    GoalSeries[]
  goalOverrides GoalOccurrenceOverride[]
  goalCompletions GoalCompletion[]
}

model Goal {
  id          String    @id @default(cuid())
  uid         String
  date        String
  text        String
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [uid], references: [uid], onDelete: Cascade)
  completions GoalCompletion[]

  @@index([uid, date])
}

model GoalSeries {
  id             String                   @id @default(cuid())
  uid            String
  text           String
  recurrenceType RecurrenceType
  interval       Int                      @default(1)
  daysOfWeek     Int[]                    @default([])
  dayOfMonth     Int?
  startDate      String
  endDate        String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  user           User                     @relation(fields: [uid], references: [uid], onDelete: Cascade)
  overrides      GoalOccurrenceOverride[]
  completions    GoalCompletion[]

  @@index([uid, startDate])
  @@index([uid, recurrenceType])
}

model GoalOccurrenceOverride {
  id           String     @id @default(cuid())
  seriesId     String
  uid          String
  date         String
  overrideText String?
  isSkipped    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  series       GoalSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [uid], references: [uid], onDelete: Cascade)

  @@unique([seriesId, date])
  @@index([uid, date])
}

model GoalCompletion {
  id          String     @id @default(cuid())
  uid         String
  seriesId    String?
  goalId      String?
  date        String
  completed   Boolean    @default(false)
  completedAt DateTime?
  series      GoalSeries? @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  goal        Goal?      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [uid], references: [uid], onDelete: Cascade)

  @@unique([uid, date, seriesId])
  @@index([uid, date])
}

model DayNote {
  id        String   @id @default(cuid())
  uid       String
  date      String
  notes     String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [uid], references: [uid], onDelete: Cascade)

  @@unique([uid, date])
  @@index([uid, date])
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}
