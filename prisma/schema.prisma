generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  uid           String    @id
  email         String?
  displayName   String?
  photoURL      String?
  username      String?
  usernameLower String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  goals         Goal[]
  dayNotes      DayNote[]
}

model Goal {
  id          String    @id @default(cuid())
  uid         String
  date        String
  text        String
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [uid], references: [uid], onDelete: Cascade)

  @@index([uid, date])
}

model DayNote {
  id        String   @id @default(cuid())
  uid       String
  date      String
  notes     String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [uid], references: [uid], onDelete: Cascade)

  @@unique([uid, date])
  @@index([uid, date])
}
